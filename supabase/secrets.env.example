# ═══════════════════════════════════════════════════════
# Job Fortress — Supabase Edge Function Secrets
# Set ALL of these in: Supabase Dashboard → Project Settings → Edge Functions → Secrets
# DO NOT commit the filled-in version to git
# ═══════════════════════════════════════════════════════

# ── AI / Language Model APIs ──────────────────────────
LOVABLE_API_KEY=            # Primary AI orchestrator — get from your AI provider dashboard
PERPLEXITY_API_KEY=         # Company intelligence & enrichment — https://www.perplexity.ai/settings/api
GROQ_API_KEY=               # Fallback fast inference — https://console.groq.com/keys
GEMINI_API_KEY=             # Google AI (resume analysis, OG image) — https://aistudio.google.com/app/apikey

# ── Web Search & Enrichment ───────────────────────────
FIRECRAWL_API_KEY=          # Web scraping & LinkedIn enrichment — https://www.firecrawl.dev/app/api-keys
TAVILY_API_KEY=             # Search intelligence — https://app.tavily.com/home (API Keys tab)

# ── Job Market Data ───────────────────────────────────
ONET_USERNAME=              # O*NET job taxonomy API — register at https://services.onetcenter.org/
ONET_PASSWORD=              # O*NET password (same registration)
ADZUNA_API_ID=              # Salary data India — https://developer.adzuna.com/ (App ID)
ADZUNA_API_KEY=             # Adzuna API Key (same dashboard)

# ── Payments ──────────────────────────────────────────
RAZORPAY_KEY_ID=            # Razorpay Key ID — Dashboard → Settings → API Keys (use rzp_live_ for prod)
RAZORPAY_KEY_SECRET=        # Razorpay Key Secret — same location, NEVER expose in frontend
RAZORPAY_WEBHOOK_SECRET=    # Razorpay Webhook Secret — Dashboard → Webhooks → create webhook → copy secret

# ── Infrastructure ────────────────────────────────────
ML_BASE_URL=                # Your ML prediction server base URL (e.g. https://ml.yourdomain.com)
ALERT_WEBHOOK_URL=          # Slack/PagerDuty webhook for monitoring alerts
ADMIN_PASSWORD=             # Strong password for admin-dashboard access (generate with: openssl rand -base64 32)

# ── Testing (can be omitted in production) ────────────
PIPELINE_TEST_EMAIL=        # Test account email for automated pipeline tests
PIPELINE_TEST_PASS=         # Test account password

# ══ NOTE: These are AUTO-INJECTED by Supabase — DO NOT set manually ══
# SUPABASE_URL              — auto-set to your project URL
# SUPABASE_SERVICE_ROLE_KEY — auto-set to your service role key
# SUPABASE_ANON_KEY         — auto-set to your anon/publishable key
